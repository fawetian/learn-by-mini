        <mxCell id="e_choice_pending" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=1;exitY=0.35;entryX=0;entryY=0.5;" edge="1" parent="1" source="choice_immediate" target="pending">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_choice_scheduled" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d6b656;exitX=0.55;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="choice_immediate" target="scheduled">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="835" y="275" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_scheduled_forwarder" value="到期扫描" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=1;exitY=0.5;entryX=0;entryY=0.75;" edge="1" parent="1" source="scheduled" target="forwarder">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_forwarder_pending" value="搬回 pending" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=0;exitY=0.25;entryX=1;entryY=0.3;" edge="1" parent="1" source="forwarder" target="pending">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1370" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_pending_dequeue" value="Server.Start 后 processor 轮询" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="pending" target="dequeue">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1175" y="370" />
              <mxPoint x="250" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_dequeue_active" value="原子抢占" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="dequeue" target="active">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_active_load" value="读 msg" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#9673a6;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="active" target="load_msg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_load_handler" value="执行业务" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#6c8ebf;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="load_msg" target="handler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_handler_success" value="返回结果" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d6b656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="handler" target="choice_success">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_success_done" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.75;entryY=0;" edge="1" parent="1" source="choice_success" target="done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_success_retry_choice" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=0;exitY=0.55;entryX=1;entryY=0.35;" edge="1" parent="1" source="choice_success" target="choice_retry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_retry_choice_retry" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=0;exitY=0.5;entryX=1;entryY=0.45;" edge="1" parent="1" source="choice_retry" target="retry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_retry_forwarder" value="retry 到期后回流" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="retry" target="forwarder">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="930" y="435" />
              <mxPoint x="1590" y="435" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_retry_choice_archive" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#b85450;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="choice_retry" target="archive">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1210" y="820" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_crash_recoverer" value="lease 超时" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#b85450;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="crash" target="recoverer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_recoverer_choice" value="扫描过期 lease" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#b85450;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="recoverer" target="choice_recover_retry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_recover_choice_retry" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#d79b00;exitX=0.35;exitY=0;entryX=0.25;entryY=1;" edge="1" parent="1" source="choice_recover_retry" target="retry">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="910" y="830" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_recover_choice_archive" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#b85450;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="choice_recover_retry" target="archive">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
